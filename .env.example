# ─── Red privada (VPC de DigitalOcean) ───────────────────────────────────────
# IP privada de este Droplet: DigitalOcean → tu Droplet → Networking → Private IP
BIND_HOST=10.124.0.3

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=sylvara
POSTGRES_USER=sylvara_user
POSTGRES_PASSWORD=sylvara2gg

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_PORT=27017
MONGO_DB=sylvara_db
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootsylvara2gg
MONGO_APP_USER=sylvara_app
MONGO_APP_PASSWORD=sylvara2gg

# ─── pgAdmin (perfil: tools) ──────────────────────────────────────────────────
# Dejar en 127.0.0.1 — acceso solo vía SSH tunnel
PGADMIN_BIND_HOST=127.0.0.1
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@sylvara.com
PGADMIN_PASSWORD=sylvara2gg

# ─── Mongo Express (perfil: tools) ────────────────────────────────────────────
ME_PORT=8081
ME_USER=admin
ME_PASSWORD=sylvara2gg
